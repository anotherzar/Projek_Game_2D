  whiteFlash: {fileID: 1070910648}
  darkOverlay: {fileID: 2089021500}
  aren: {fileID: 817954462}
  luma: {fileID: 900369115}
  namaImageAren: {fileID: 513360757}
  namaImageLuma: {fileID: 1900365910}
  namaImageChild: {fileID: 2045069301}
  namaImageShadowInk: {fileID: 379916150}
  namaImageAnakKecil: {fileID: 2045069301}
  lostChildSad: {fileID: 504091168}
  lostChildHappy: {fileID: 480834605}
  shadowInk: {fileID: 37807616}
  bgCards: {fileID: 1247122263}
  bgLight: {fileID: 726149303}
  introLines:
  - speaker: 
    text: Tulisan pada halaman kembali muncul.
  - speaker: 
    text: Cahaya perlahan memenuhi lorong.
  - speaker: 
    text: Anak kecil tadi mengangkat wajahnya.
  memoryLines:
  - speaker: child
    text: '"Aku ingat..."'
  - speaker: child
    text: '"Aku tinggal di dekat taman cahaya..."'
  - speaker: 
    text: Ia tersenyum kecil sebelum pergi.
  - speaker: 
    text: Aren memperhatikan itu diam-diam.
  - speaker: Aren
    text: '"Jadi puzzle tadi... bukan sekadar permainan ya."'
  - speaker: Luma
    text: '"Cerita dunia ini dibangun dari ingatan."'
  - speaker: Luma
    text: '"Kalau ingatannya kembali... maka ceritanya ikut hidup lagi."'
  shadowLines:
  - speaker: 
    text: Namun tiba-tiba tinta hitam mulai muncul di dinding lorong.
  - speaker: 
    text: Suara berat terdengar menggema.
  - speaker: Shadow Ink
    text: '"Kalian hanya memperlambat akhir cerita ini."'
  - speaker: 
    text: Bayangan hitam besar muncul sesaat sebelum menghilang kembali.
  - speaker: Aren
    text: '"Apa itu?!"'
  - speaker: Luma
    text: '"Shadow Ink..."'
  - speaker: Luma
    text: '"Dia mulai mendekat."'
  sceneEnding: Ending_1
  audioSource: {fileID: 0}
  bgmVolume: 0.5
  sfxVolume: 1
  bgmLevel: {fileID: 8300000, guid: 806ac74e283c27944af10cdac2ff12ff, type: 3}
